{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Plaud Dev API",
  "colors": {
    "primary": "#0f172a",
    "light": "#FFFFFF",
    "dark": "#16171f"
  },
  "styling": {
    "codeblocks": "system"
  },
  "favicon": "/assets/favicon/light.svg",
  "api": {
    "examples": {
      "languages": ["curl", "python"],
      "defaults": "all"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "GET STARTED",
            "pages": [
              "/documentation/get_started/overview",
              "/documentation/get_started/quickstart",
              "/documentation/get_started/changelog"
            ]
          },
          {
            "group": "CAPABILITIES",
            "pages": [
              "/documentation/capabilities/device_operations",
              "/documentation/capabilities/file_management",
              "/documentation/capabilities/transcription",
              "/documentation/capabilities/ai_summary",
              "/documentation/capabilities/ai_workflow"
            ]
          },
          {
            "group": "DEVELOPER GUIDES",
            "pages": [
              {
                "group": "Tutorials",
                "icon": "code",
                "iconType": "duotone",
                "pages": [
                  "/documentation/developer_guides/tutorials/device_operations",
                  "/documentation/developer_guides/tutorials/files",
                  "/documentation/developer_guides/tutorials/ai_workflow"
                ]
              },
              
              "/documentation/developer_guides/libraries",
              "/documentation/developer_guides/errors",
              "/documentation/developer_guides/webhook_events"
            ]
          }
        ]
      },
    {
      "tab": "API Guide",
      "groups": [
        {
          "group": "API REFERENCE",
          "pages": [
            "/api_guide/api_intro/overview",
            "/api_guide/api_intro/authorization",
            "/api_guide/api_intro/rate_limit"
          ]
        },
        {
          "group": "ENDPOINTS",
          "openapi": "https://platform.plaud.ai/openapi.json",
          "pages": [
            {
              "group": "Oauth",
              "pages": ["POST /api/oauth/api-token"]
            },
            {
              "group": "Devices",
              "pages": [
                "GET /api/devices/{device_id}",
                "POST /api/devices/bind",
                "POST /api/devices/unbind"
              ]
            },
            {
              "group": "Files",
              "pages": [
                "GET /api/files/{file_id}",
                "POST /api/files/upload-s3/generate-presigned-urls",
                "POST /api/files/upload-s3/complete-upload"
              ]
            },
            {
              "group": "Workflows",
              "pages": [
                "GET /api/workflows/{workflow_id}/result",
                "GET /api/workflows/{workflow_id}/status",
                "POST /api/workflows/submit"
              ]
            }
          ]
        },
        {
          "group": "SDK",
          "pages": [
            "/api_guide/sdks/overview",
            "/api_guide/sdks/ios",
            "/api_guide/sdks/android"
          ]
        }
      ]
    }
    ]
  },
  "logo": {
    "light": "/assets/logo/light.svg",
    "dark": "/assets/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Request Access",
        "href": "https://docs.google.com/forms/d/e/1FAIpQLSeMr2cRAjrWK79k6HuPOjeOoU7bqHDbk1ZQTsH3RZ8rhJPwAg/viewform",
        "icon": "key"
      },
      {
        "label": "Community",
        "href": "https://join.slack.com/t/plaudaidevcommunity/shared_invite/zt-393rhhb2f-nuZkeX3byDxEK3AEtJCsUw",
        "icon": "slack"
      },
      {
        "label": "Contact Us",
        "href": "mailto:dev-support@plaud.ai",
        "icon": "envelope"
      }
    ]
  },
  "footer": {
    "socials":{
      "website": "https://plaud.ai",
      "github": "https://github.com/Plaud-AI/plaud-sdk"
    }
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true,
    "thumbsRating": true
  },
  "modeToggle": {
    "default": "light",
    "isHidden": false
  },
  "backgroundImage": "/images/background.png",
  "stylesheets": [
    "/styles/custom.css"
  ]
}

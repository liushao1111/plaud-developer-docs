{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Plaud Dev API",
  "colors": {
    "primary": "#0f172a",
    "light": "#FFFFFF",
    "dark": "#16171f"
  },
  "favicon": "/assets/favicon.svg",
  "api": {
    "examples": {
      "languages": ["curl", "python"],
      "defaults": "all"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "GET STARTED",
            "pages": [
              "/documentation/get-started/overview",
              "/documentation/get-started/quickstart",
              "/documentation/get-started/dashboard"
            ]
          },
          {
            "group": "CAPABILITIES",
            "pages": [
              "/documentation/capabilities/ai_summary",
              "/documentation/capabilities/ai_workflow"
            ]
          },
          {
            "group": "DEVELOPER GUIDES",
            "pages": [
              {
                "group": "Tutorials",
                "pages": [
                  "/documentation/tutorials/ai_summary",
                  "/documentation/tutorials/ai_workflow"
                ]
              },
              "/documentation/developer-guides/libraries",
              "/documentation/developer-guides/errors"
            ]
          },
          {
            "group": "PRODUCT GUIDES",
            "pages": [
              "/documentation/product-guides/overview",
              {
                "group": "Playground",
                "pages": [
                  "/documentation/playground/ai_workflow"
                ]
              },
              {
                "group": "Products",
                "pages": [
                  "/documentation/products/ai_workflow"
                ]
              },
              {
                "group": "Adminstration",
                "pages": [
                  "/documentation/administration/usage",
                  "/documentation/administration/webhook"
                ]
              }
            ]
          }
          
        ]
      },
    {
      "tab": "AI Platform",
      "groups": [
        {
          "group": "GET STARTED",
          "pages": [
            "/ai-platform/get-started/overview",
            "/ai-platform/get-started/quickstart",
            "/ai-platform/get-started/dashboard"
          ]
        },
        {
          "group": "BEST PRACTICES",
          "pages": [
            "/ai-platform/best-practices/workflow"
          ]
        }
      ]
    },
    {
      "tab": "API Guide",
      "groups": [
        {
          "group": "Using the APIs",
          "pages": [
            "/api-guide/api_intro/overview",
            "/api-guide/api_intro/rate_limit",
            "/api-guide/api_intro/error_messages"
          ]
        },
        {
          "group": "API Reference",
          "openapi": {
            "source": "https://platform.plaud.ai/openapi.json"
          }
        },
        {
          "group": "SDKs",
          "pages": [
            "/api-guide/sdks/overview",
            "/api-guide/sdks/ios",
            "/api-guide/sdks/android"
          ]
        }
      ]
    },
    {
      "tab": "Release Note",
      "groups": [
        {
          "group": "Release Notes",
          "pages": [
            "/release-notes/overview",
            "/release-notes/api",
            "/release-notes/sdk",
            "/release-notes/ai_platform"
          ]
        }
      ]
    }
    ]
  },

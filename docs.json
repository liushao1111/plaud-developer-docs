{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Plaud Dev API",
  "colors": {
    "primary": "#0f172a",
    "light": "#FFFFFF",
    "dark": "#16171f"
  },
  "favicon": "/favicon.svg",
  "api": {
    "examples": {
      "languages": ["curl", "python"],
      "defaults": "all"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API Reference",
        "groups": [
          {

            "group": "Endpoints",
            "openapi": {
              "source": "/api/openapi.json",
              "directory": "api-reference"
            }
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:lucas@plaud.ai"
      }
    ]
  },
  "footerSocials": {
    "website": "https://plaud.ai",
    "facebook": "https://www.facebook.com/plaudai",
    "x": "https://x.com/PLAUDAI",
    "instagram": "https://www.instagram.com/accounts/login/?next=https%3A%2F%2Fwww.instagram.com%2Fplaud_official%2F&is_from_rle",
    "youtube": "https://www.youtube.com/@PLAUDAI"
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true,
    "thumbsRating": true
  },
  "modeToggle": {
    "default": "light",
    "isHidden": false
  },
  "backgroundImage": "/images/background.png",
  "topbarLinks": [
    {
      "name": "Contact Us",
      "url": "mailto:support@plaud.ai"
    }
  ],
  "topbarCtaButton": {
    "name": "Get API Key",
    "url": "https://console.plaud.ai"
  },
  "stylesheets": [
    "/styles/custom.css"
  ]
}

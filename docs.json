{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Plaud Dev API",
  "colors": {
    "primary": "#0f172a",
    "light": "#FFFFFF",
    "dark": "#16171f"
  },
  "favicon": "/favicon.svg",
  "api": {
    "examples": {
      "languages": ["curl", "python"],
      "defaults": "all"
    }
  },
  "navigation": {
  "tabs": [
    {
      "tab": "Guides",
      "groups": [
        {
          "group": "Getting Started",
          "pages": [
            "/getting-started/overview",
            "/getting-started/api",
            "/getting-started/sdk"
          ]
        },
        {
          "group": "Feature Guides",
          "pages": [
            "guides/device-management",
            "guides/user-management",
            "guides/file-management"
          ]
        }
      ]
    },
    {
      "tab": "API Reference",
      "groups": [
        {
          "group": "API Reference",
          "openapi": {
            "source": "https://platform.plaud.ai/openapi.json"
          }
        }
      ]
    },
    {
      "tab": "SDK",
      "groups": [
        {
          "group": "Mobile SDK",
          "collapsible": true,
          "pages": [
            {
              "group": "iOS SDK",
              "pages": [
                "sdk/ios/overview",
                "sdk/ios/get-started",
                "sdk/ios/reference"
              ]
            },
            {
              "group": "Android SDK",
              "pages": [
                "sdk/android/overview",
                "sdk/android/get-started",
                "sdk/android/reference"
              ]
            }
          ]
        }
      ]
    }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Community",
        "href": "https://join.slack.com/t/plaudaidevcommunity/shared_invite/zt-393rhhb2f-nuZkeX3byDxEK3AEtJCsUw",
        "icon": "slack"
      },
      {
        "label": "Help",
        "href": "mailto:dev-support@plaud.ai",
        "icon": "envelope"
      }
    ]
  },
  "footer": {
    "socials":{
      "website": "https://plaud.ai",
      "github": "https://github.com/Plaud-AI/plaud-sdk",
      "slack": "https://join.slack.com/t/plaudaidevcommunity/shared_invite/zt-393rhhb2f-nuZkeX3byDxEK3AEtJCsUw"
    },
    "links": [
      {
        "header": "Resources",
        "items": [
          {
            "label": "Customers",
            "href": "https://example.com/customers"
          },
          {
            "label": "Enterprise",
            "href": "https://example.com/enterprise"
          },
          {
            "label": "Request Preview",
            "href": "https://example.com/preview"
          }
        ]
      },
      {
        "header": "Company",
        "items": [
          {
            "label": "Careers",
            "href": "https://example.com/careers"
          },
          {
            "label": "Blog",
            "href": "https://example.com/blog"
          },
          {
            "label": "Privacy Policy",
            "href": "https://example.com/legal/privacy"
          }
        ]
      }
    ]
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true,
    "thumbsRating": true
  },
  "modeToggle": {
    "default": "light",
    "isHidden": false
  },
  "backgroundImage": "/images/background.png",
  "topbarLinks": [
    {
      "name": "Contact Us",
      "url": "mailto:dev-support@plaud.ai"
    }
  ],
  "topbarCtaButton": {
    "name": "Get API Key",
    "url": "https://console.plaud.ai"
  },
  "stylesheets": [
    "/styles/custom.css"
  ]
}

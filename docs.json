{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Plaud Dev API",
  "colors": {
    "primary": "#0f172a",
    "light": "#FFFFFF",
    "dark": "#16171f"
  },
  "favicon": "/favicon.svg",
  "api": {
    "examples": {
      "languages": ["curl", "python"],
      "defaults": "all"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "icon": "book-open",
        "pages": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Feature Guides",
            "pages": [
              "guides-overview",
              "guides/device-management",
              "guides/user-management",
              "guides/file-management"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "code",
        "anchors": [
          {
            "anchor": "Tenant Management",
            "icon": "building",
            "pages": [
              "docs/api-reference/tenant-management/get-tenant-list",
              "docs/api-reference/tenant-management/create-tenant",
              "docs/api-reference/tenant-management/get-tenant-by-id",
              "docs/api-reference/tenant-management/delete-tenant-by-id",
              "docs/api-reference/tenant-management/update-tenant"
            ]
          },
          {
            "anchor": "User Management",
            "icon": "user",
            "pages": [
              "docs/api-reference/user-management/get-user-list",
              "docs/api-reference/user-management/create-user",
              "docs/api-reference/user-management/get-user-by-id",
              "docs/api-reference/user-management/delete-user-by-id",
              "docs/api-reference/user-management/update-user",
              "docs/api-reference/user-management/bind-device-to-user",
              "docs/api-reference/user-management/unbind-device-from-user"
            ]
          },
          {
            "anchor": "Device Management",
            "icon": "device-mobile",
            "pages": [
              "docs/api-reference/device-management/get-device-list",
              "docs/api-reference/device-management/create-device",
              "docs/api-reference/device-management/get-device-by-id",
              "docs/api-reference/device-management/delete-device-by-id",
              "docs/api-reference/device-management/update-device"
            ]
          },
          {
            "anchor": "File Operations",
            "icon": "file",
            "pages": [
              "docs/api-reference/file-operations/get-file-list",
              "docs/api-reference/file-operations/get-file-by-id",
              "docs/api-reference/file-operations/delete-file-by-id",
              "docs/api-reference/file-operations/update-file",
              "docs/api-reference/file-operations/ai-file",
              "docs/api-reference/file-operations/merge-file"
            ]
          }
        ]
      }
    ],
    "global": {}
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:lucas@plaud.ai"
      }
    ]
  },
  "footerSocials": {
    "website": "https://plaud.ai",
    "facebook": "https://www.facebook.com/plaudai",
    "x": "https://x.com/PLAUDAI",
    "instagram": "https://www.instagram.com/accounts/login/?next=https%3A%2F%2Fwww.instagram.com%2Fplaud_official%2F&is_from_rle",
    "youtube": "https://www.youtube.com/@PLAUDAI"
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true,
    "thumbsRating": true
  },
  "modeToggle": {
    "default": "light",
    "isHidden": false
  },
  "backgroundImage": "/images/background.png",
  "topbarLinks": [
    {
      "name": "Contact Us",
      "url": "mailto:support@plaud.ai"
    }
  ],
  "topbarCtaButton": {
